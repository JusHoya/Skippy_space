# Skippy_space — environment template
# Copy this file to `.env` (gitignored) and fill in real values.
# Tauri dev/build, the Node sidecar, and OTel all read these.

# ---- Required for the agent-runtime sidecar ----
# Your Anthropic API key. Used by Skippy + every Board agent.
ANTHROPIC_API_KEY=

# ---- Optional model overrides (per PRD §3.3) ----
# Skippy is Opus by default — cost-disciplined orchestrator.
SKIPPY_MODEL=claude-opus-4-7
# Future Board defaults (used in Phase 1; ignored in Phase 0).
BOARD_DEFAULT_MODEL_SONNET=claude-sonnet-4-6
BOARD_DEFAULT_MODEL_HAIKU=claude-haiku-4-5-20251001

# ---- Telemetry ----
# Local OTel collector endpoint (the Rust shell hosts this in Phase 1+).
# Phase 0: leave empty or unreachable — the sidecar soft-fails and continues.
# Phase 1: the sidecar docker collector listens on :4319 (NOT :4318 — that
# port is taken by Langfuse's own ingest). Updated in the Phase 1 section
# below; the value here is the Phase 0 default.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ---- Logging ----
# Pino level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ---- Letta (Phase 1+) ----
# Self-hosted Letta server URL. Skippy's hot memory layer.
LETTA_BASE_URL=http://localhost:8283

# ---- Langfuse (Phase 1+) ----
# Self-hosted Langfuse OTLP endpoint, separate from the local collector.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Tauri development ----
# Set to 1 to disable sidecar auto-restart (handy when iterating the runtime).
SKIPPY_NO_RESTART=

# Phase 1 — telemetry
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# OTel collector (in dev, sidecar Docker container; in v1, embedded in Tauri shell)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4319/v1/traces

# Letta
LETTA_BASE_URL=http://localhost:8283
