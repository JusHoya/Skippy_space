{
  "name": "skippy-space",
  "version": "0.0.1",
  "private": true,
  "description": "Skippy_space — RTS-style desktop AI agent orchestration dashboard",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @skippy/shell dev",
    "dev:ui": "pnpm --filter @skippy/ui dev",
    "dev:runtime": "pnpm --filter @skippy/agent-runtime dev",
    "build": "pnpm -r build",
    "build:runtime": "pnpm --filter @skippy/agent-runtime build",
    "tauri": "pnpm --filter @skippy/shell tauri",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "autocommit": "node scripts/git-autocommit.mjs --once",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:headed": "playwright test --headed",
    "validate:phase0": "node scripts/phase0-validate.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
